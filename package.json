{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "imagecheck": "node scripts/imagecheck.cjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check": "node scripts/check.js",
    "backend:fixed": "node api/server.cjs",
    "backend": "nodemon api/server.cjs",
    "start": "concurrently \"pnpm dev\" \"pnpm backend\"",
    "refresh-clients": "node scripts/refresh-clients.cjs",
    "thumbs": "node scripts/generate-thumbs.cjs",
    "thumbs:new": "node scripts/generate-thumbs.cjs --new",
    "thumbs:id": "node scripts/generate-thumbs.cjs --id",
    "test:e2e": "cucumber-js --import ts-node/register --import tests/e2e/support/world.ts --import tests/e2e/step-definitions/**/*.ts tests/e2e/features/**/*.feature",
    "test:e2e:browser": "E2E_HEADLESS=false E2E_SLOW_MO=1000 cucumber-js --import ts-node/register --import tests/e2e/support/world.ts --import tests/e2e/step-definitions/**/*.ts tests/e2e/features/**/*.feature"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsvectormap": "^1.7.0",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.2.2",
    "nodemon": "^3.0.2",
    "playwright": "^1.60.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "storybook": "^10.3.6",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
