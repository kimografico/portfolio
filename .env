# Ruta base de las portadas de libros
# Esta variable permite cambiar la ubicación de las portadas sin modificar el código
VITE_BOOK_COVERS_PATH=/portfolio/images/books

# Ruta base de las ilustraciones
VITE_ILLUSTRATIONS_PATH=/portfolio/images/illustrations

# Ruta base de imágenes de UI (mapas, fondos, etc)
VITE_UI_IMG_PATH=/portfolio/images/ui
